{
  "name": "@blue-matter/core",
  "version": "1.0.0",
  "description": "A TypeScript library for parsing front matter in Markdown files.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test tests/*.test.ts",
    "test:watch": "node --test --watch tests/*.test.ts",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "front-matter",
    "yaml",
    "markdown",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.2",
    "typescript": "^5.6.0"
  }
}
